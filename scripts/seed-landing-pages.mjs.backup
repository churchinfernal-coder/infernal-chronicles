function generateStateContent(stateName, countryName, lang) {
  if (lang === 'es') return {
    h1_title: `I.C.O.S ${stateName} - Comunidad Infernalista`,
    h2_subtitle: `Conéctate con Infernalistas en ${stateName}`,
    hero_description: `Únete a la comunidad infernalista de ${stateName}. Estudia la biblia infernal y camina por el sendero de Satán.`,
    about_title: `La Comunidad Infernalista de ${stateName}`,
    about_content: `I.C.O.S ${stateName} da la bienvenida a buscadores de sabiduría infernal. Reuniones regulares y apoyo comunitario.`,
    cta_primary_text: 'Únete a infernalsocial.com',
    feature_1_title: 'Red Regional',
    feature_1_description: `Capítulos en ${stateName}`,
    feature_2_title: 'Reuniones Regulares',
    feature_2_description: 'Grupos de estudio semanales',
    feature_3_title: 'Apoyo Local',
    feature_3_description: 'Conéctate con infernalistas locales',
  };
  return {
    h1_title: `I.C.O.S ${stateName} - Infernalist Community`,
    h2_subtitle: `Connect with Infernalists Across ${stateName}`,
    hero_description: `Join the ${stateName} infernalist community. Study the infernal bible and walk the path of Satan.`,
    about_title: `The ${stateName} Infernalist Community`,
    about_content: `I.C.O.S ${stateName} welcomes seekers of infernal wisdom. Regular gatherings and community support.`,
    cta_primary_text: 'Join infernalsocial.com',
    feature_1_title: 'Regional Network',
    feature_1_description: `Chapters across ${stateName}`,
    feature_2_title: 'Regular Gatherings',
    feature_2_description: 'Weekly study groups',
    feature_3_title: 'Local Support',
    feature_3_description: 'Connect with local infernalists',
  };
}

function generateCityContent(cityName, stateName, lang) {
  if (lang === 'es') return {
    h1_title: `I.C.O.S ${cityName} - Capítulo Local`,
    h2_subtitle: `Conoce Infernalistas en ${cityName}`,
    hero_description: `El capítulo de ${cityName} ofrece una comunidad para infernalistas locales.`,
    about_title: `Capítulo Local de I.C.O.S ${cityName}`,
    about_content: `El capítulo de ${cityName} proporciona reuniones regulares y estudio de la biblia infernal.`,
    cta_primary_text: 'Únete a infernalsocial.com',
    feature_1_title: 'Reuniones Locales',
    feature_1_description: `Encuentros en ${cityName}`,
    feature_2_title: 'Estudio Bíblico',
    feature_2_description: 'Grupos semanales',
    feature_3_title: 'Comunidad Local',
    feature_3_description: `Infernalistas de ${cityName}`,
  };
  return {
    h1_title: `I.C.O.S ${cityName} - Local Chapter`,
    h2_subtitle: `Meet Fellow Infernalists in ${cityName}`,
    hero_description: `The ${cityName} chapter provides a welcoming community for local infernalists.`,
    about_title: `I.C.O.S ${cityName} Local Chapter`,
    about_content: `The ${cityName} chapter offers regular gatherings and infernal bible study.`,
    cta_primary_text: 'Join infernalsocial.com',
    feature_1_title: 'Local Meetings',
    feature_1_description: `Gatherings in ${cityName}`,
    feature_2_title: 'Bible Study',
    feature_2_description: 'Weekly groups',
    feature_3_title: 'Local Community',
    feature_3_description: `${cityName} infernalists`,
  };
}

function generateSEO(type, name, parentName, countrySlug, stateSlug, lang) {
  const baseUrl = 'https://infernalsocial.com';
  let url = `${baseUrl}/landing/${countrySlug}`;
  if (stateSlug) url += `/${stateSlug}`;
  if (type === 'city') url += `/${name.toLowerCase().replace(/\s+/g, '-')}`;
  const keywords = ['infernal church of satan', 'infernalism', 'infernal bible', 'infernalist', 'satan', 'ICOS', 'I.C.O.S', `I.C.O.S ${name}`];
  if (lang === 'es') return {
    meta_title: `I.C.O.S ${name} | Infernalismo`,
    meta_description: `Comunidad infernalista de ${name}. Estudia la biblia infernal en ${name}.`,
    meta_keywords: keywords,
    canonical_url: url,
    robots: 'index, follow',
    og_type: 'website',
    twitter_card: 'summary_large_image',
  };
  return {
    meta_title: `I.C.O.S ${name} | Infernalism`,
    meta_description: `${name} infernalist community. Study the infernal bible in ${name}.`,
    meta_keywords: keywords,
    canonical_url: url,
    robots: 'index, follow',
    og_type: 'website',
    twitter_card: 'summary_large_image',
  };
}

async function seedDatabase() {
  console.log(' COMPLETE PRODUCTION SEED STARTING\n');
  let totalStates = 0, totalCities = 0, totalContent = 0, totalSEO = 0;
  for (const [isoCode, countryData] of Object.entries(COMPLETE_DATA)) {
    const { data: country } = await supabase.from('countries').select('id, name, slug').eq('iso_code', isoCode).single();
    if (!country) continue;
    console.log(` ${country.name}`);
    for (const stateData of countryData.states) {
      const { data: state } = await supabase.from('states').upsert({
        country_id: country.id,
        name: stateData.name,
        slug: stateData.slug,
        state_code: stateData.code,
        is_active: true,
      }, { onConflict: 'country_id,slug' }).select().single();
      if (!state) continue;
      totalStates++;
      console.log(`   ${stateData.name}`);
      for (const lang of ['en', 'es']) {
        await supabase.from('landing_page_content').upsert({
          location_type: 'state',
          location_id: state.id,
          language_code: lang,
          ...generateStateContent(stateData.name, country.name, lang),
        }, { onConflict: 'location_type,location_id,language_code' });
        await supabase.from('landing_seo_metadata').upsert({
          entity_type: 'state',
          entity_id: state.id,
          language_code: lang,
          ...generateSEO('state', stateData.name, country.name, country.slug, stateData.slug, lang),
        }, { onConflict: 'entity_type,entity_id,language_code' });
        totalContent++; totalSEO++;
      }
      for (const cityData of stateData.cities) {
        const { data: city } = await supabase.from('cities').upsert({
          state_id: state.id,
          country_id: country.id,
          name: cityData.name,
          slug: cityData.slug,
          latitude: cityData.lat,
          longitude: cityData.lon,
          population: cityData.pop,
          is_active: true,
        }, { onConflict: 'state_id,slug' }).select().single();
        if (!city) continue;
        totalCities++;
        console.log(`     ${cityData.name}`);
        for (const lang of ['en', 'es']) {
          await supabase.from('landing_page_content').upsert({
            location_type: 'city',
            location_id: city.id,
            language_code: lang,
            ...generateCityContent(cityData.name, stateData.name, lang),
          }, { onConflict: 'location_type,location_id,language_code' });
          await supabase.from('landing_seo_metadata').upsert({
            entity_type: 'city',
            entity_id: city.id,
            language_code: lang,
            ...generateSEO('city', cityData.name, stateData.name, country.slug, stateData.slug, lang),
          }, { onConflict: 'entity_type,entity_id,language_code' });
          totalContent++; totalSEO++;
        }
      }
    }
  }
  console.log(`\n COMPLETE! States: ${totalStates} | Cities: ${totalCities} | Content: ${totalContent} | SEO: ${totalSEO}`);
}

seedDatabase().catch(console.error);

